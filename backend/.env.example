# ─── Server ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
# NOTE: เปลี่ยน PORT ทุกร้าน (3001, 3002, 3003, ...)

# ─── Frontend URL (CORS) ───────────────────────────────────────────
FRONTEND_URL=https://SUBDOMAIN.yourdomain.com

# ─── Database ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=resto_SLUG_user
DB_PASS=ChangeMe_StrongPassword!
DB_NAME=restaurant_SLUG

# ─── Admin Auth ────────────────────────────────────────────────────
ADMIN_EMAILS=owner@gmail.com
ADMIN_PASSWORD=ChangeMe_AdminPassword!
JWT_SECRET=run: openssl rand -hex 32

# ─── Telegram Bot ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
